{
  "name": "reddone-control-plane",
  "version": "0.1.0",
  "private": true,
  "description": "A private, approval-gated research-to-release control plane.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24.18 <25"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack && node scripts/prepare-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:browser": "pnpm build && playwright test",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "owner-code:create": "tsx scripts/owner-access-code.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@daytona/sdk": "0.196.0",
    "@google-cloud/kms": "5.5.0",
    "@google-cloud/storage": "7.21.0",
    "@octokit/auth-app": "8.2.0",
    "@octokit/rest": "22.0.1",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@tanstack/react-query": "5.101.2",
    "@vercel/oidc": "3.8.0",
    "@vercel/sdk": "1.28.8",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "17.2.3",
    "google-auth-library": "10.9.0",
    "lucide-react": "0.552.0",
    "next": "16.2.10",
    "openai": "6.48.0",
    "pg": "8.16.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "sharp": "0.34.5",
    "stripe": "^22.3.2",
    "tailwind-merge": "3.3.1",
    "workflow": "4.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/pg": "8.15.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.2",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "jsdom": "27.1.0",
    "postcss": "8.5.19",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vercel": "56.3.1",
    "vitest": "4.1.10"
  }
}
