#!/bin/sh
set -eu
cd /workspace
if grep -RIE --exclude-dir=.next --exclude-dir=node_modules --exclude='*.map' '(AKIA|ASIA)[A-Z0-9]{16}|github_pat_[A-Za-z0-9_]{20,}|gh[opsu]_[A-Za-z0-9]{20,}|(sk|rk)_(test|live)_[A-Za-z0-9_]{16,}|whsec_[A-Za-z0-9_]{16,}|sk-[A-Za-z0-9_-]{16,}|BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY' src public .vercel/output .vercel/preview-output 2>/dev/null; then
  echo "secret-like value found"
  exit 1
fi
echo "secret scan passed"
