model CreditLedger {
  id                     String           @id @default(uuid()) @db.Uuid
  workspaceId            String           @db.Uuid
  creditAccountId        String           @db.Uuid
  reservationId          String?          @db.Uuid
  subscriptionPeriodId   String?          @db.Uuid
  checkoutSessionId      String?          @db.Uuid
  creditLotId            String?          @db.Uuid
  creditCodeRedemptionId String?          @db.Uuid
  stripeEventId          String?          @db.VarChar(255)
  type                   CreditLedgerType
  bucket                 CreditBucket
  amount                 BigInt
  availableDelta         BigInt
  heldDelta              BigInt
  balanceAfterAvailable  BigInt
  balanceAfterHeld       BigInt
  idempotencyKey         String           @db.VarChar(200)
  externalReference      String?          @unique @db.VarChar(300)
  metadata               Json             @default("{}")
  occurredAt             DateTime         @db.Timestamptz(6)
  createdAt              DateTime         @default(now()) @db.Timestamptz(6)

  workspace            Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  creditAccount        CreditAccount              @relation(fields: [workspaceId, creditAccountId], references: [workspaceId, id], onDelete: Restrict)
  reservation          CreditReservation?         @relation(fields: [workspaceId, reservationId], references: [workspaceId, id], onDelete: Restrict)
  subscriptionPeriod   BillingSubscriptionPeriod? @relation(fields: [workspaceId, subscriptionPeriodId], references: [workspaceId, id], onDelete: Restrict)
  checkoutSession      BillingCheckoutSession?    @relation(fields: [workspaceId, checkoutSessionId], references: [workspaceId, id], onDelete: Restrict)
  creditLot            CreditLot?                 @relation(fields: [workspaceId, creditLotId], references: [workspaceId, id], onDelete: Restrict)
  creditCodeRedemption CreditCodeRedemption?      @relation(fields: [workspaceId, creditCodeRedemptionId], references: [workspaceId, id], onDelete: Restrict)
  stripeEvent          StripeEvent?               @relation(fields: [stripeEventId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, id])
  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, occurredAt(sort: Desc)])
  @@index([reservationId])
  @@map("credit_ledger")
}

model StripeEvent {
  id             String            @id @db.VarChar(255)
  workspaceId    String?           @db.Uuid
  type           String            @db.VarChar(150)
  mode           StripeEventMode
  apiVersion     String?           @db.VarChar(50)
  payloadHash    String            @db.Char(64)
  payload        Json
  status         StripeEventStatus @default(RECEIVED)
  eventCreatedAt DateTime          @db.Timestamptz(6)
  processedAt    DateTime?         @db.Timestamptz(6)
  failureCode    String?           @db.VarChar(100)
  failureMessage String?           @db.VarChar(1000)
  receivedAt     DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @db.Timestamptz(6)

  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  creditLots    CreditLot[]
  ledgerEntries CreditLedger[]

  @@index([workspaceId, status, receivedAt])
  @@index([status, receivedAt])
  @@map("stripe_events")
}

model ActivityEvent {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @db.Uuid
  projectId   String?          @db.Uuid
  runId       String?          @db.Uuid
  sequence    BigInt           @default(autoincrement())
  type        String           @db.VarChar(150)
  severity    ActivitySeverity @default(INFO)
  message     String           @db.VarChar(4000)
  data        Json             @default("{}")
  expiresAt   DateTime         @db.Timestamptz(6)
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sequence])
  @@index([workspaceId, projectId, createdAt(sort: Desc)])
  @@index([workspaceId, runId, sequence])
  @@index([expiresAt])
  @@map("activity_events")
}

model AuditEvent {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  actorUserId String?
  action      String   @db.VarChar(150)
  targetType  String   @db.VarChar(100)
  targetId    String   @db.VarChar(128)
  requestId   String?  @db.VarChar(200)
  ipHash      String?  @db.Char(64)
  metadata    Json     @default("{}")
  expiresAt   DateTime @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("audit_events")
}

model ProjectConversation {
  id                String   @id @default(uuid()) @db.Uuid
  workspaceId       String   @db.Uuid
  projectId         String   @db.Uuid
  title             String   @db.VarChar(120)
  summary           String?  @db.Text
  optimisticVersion Int      @default(0)
  archivedAt        DateTime? @db.Timestamptz(6)
  lastActivityAt    DateTime @default(now()) @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  workspace Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project                   @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Cascade)
  messages  ConversationMessage[]
  turns     ConversationTurn[]
  actions   ConversationAction[]

  @@unique([workspaceId, projectId, id])
  @@index([workspaceId, projectId, archivedAt, lastActivityAt(sort: Desc)])
  @@map("project_conversations")
}

model ConversationMessage {
  id             String                  @id @default(uuid()) @db.Uuid
  workspaceId    String                  @db.Uuid
  projectId      String                  @db.Uuid
  conversationId String                  @db.Uuid
  sequence       Int
  role           ConversationMessageRole
  authorUserId   String?
  content        String                  @db.Text
  contentHash    String                  @db.Char(64)
  metadata       Json                    @default("{}")
  createdAt      DateTime                @default(now()) @db.Timestamptz(6)

  conversation ProjectConversation @relation(fields: [workspaceId, projectId, conversationId], references: [workspaceId, projectId, id], onDelete: Cascade)

  @@unique([workspaceId, projectId, conversationId, sequence])
  @@unique([workspaceId, projectId, id])
  @@index([workspaceId, projectId, conversationId, createdAt])
  @@map("conversation_messages")
}

model ConversationTurn {
  id                  String                 @id @default(uuid()) @db.Uuid
  workspaceId         String                 @db.Uuid
  projectId           String                 @db.Uuid
  conversationId      String                 @db.Uuid
  ownerMessageId      String                 @db.Uuid
  status              ConversationTurnStatus @default(QUEUED)
  stateVersion        Int                    @default(0)
  idempotencyKey      String                 @db.VarChar(200)
  authorityMode       ProjectAuthorityMode
  projectVersion      Int
  modelVersion        String?                @db.VarChar(120)
  promptVersion       String?                @db.VarChar(100)
  toolsetVersion      String?                @db.VarChar(100)
  policyVersion       String?                @db.VarChar(100)
  budgetCeilingMicros BigInt                 @default(0)
  actualCostMicros    BigInt                 @default(0)
  partialResponse     String?                @db.Text
  cancelRequestedAt   DateTime?              @db.Timestamptz(6)
  startedAt           DateTime?              @db.Timestamptz(6)
  finishedAt          DateTime?              @db.Timestamptz(6)
  failureCode         String?                @db.VarChar(100)
  failureMessage      String?                @db.VarChar(1000)
  createdAt           DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime               @updatedAt @db.Timestamptz(6)

  conversation ProjectConversation      @relation(fields: [workspaceId, projectId, conversationId], references: [workspaceId, projectId, id], onDelete: Cascade)
  events              ConversationTurnEvent[]
  actions             ConversationAction[]
  lease               ConversationTurnLease?
  budgetReservations  BudgetReservation[]
  usageEntries        UsageLedger[]
  creditReservations  CreditReservation[]

  @@unique([workspaceId, idempotencyKey])
  @@unique([workspaceId, projectId, id])
  @@index([workspaceId, projectId, conversationId, status, createdAt(sort: Desc)])
  @@map("conversation_turns")
}

model ConversationTurnEvent {
  id        String                @id @default(uuid()) @db.Uuid
  workspaceId String               @db.Uuid
  projectId String                 @db.Uuid
  turnId    String                 @db.Uuid
  sequence  BigInt                 @default(autoincrement())
  type      ConversationEventType
  payload   Json                   @default("{}")
  expiresAt DateTime?              @db.Timestamptz(6)
  createdAt DateTime               @default(now()) @db.Timestamptz(6)

  turn ConversationTurn @relation(fields: [workspaceId, projectId, turnId], references: [workspaceId, projectId, id], onDelete: Cascade)

  @@unique([workspaceId, turnId, sequence])
  @@index([workspaceId, projectId, turnId, sequence])
  @@index([expiresAt])
  @@map("conversation_turn_events")
}

model ConversationAction {
  id                     String                   @id @default(uuid()) @db.Uuid
  workspaceId            String                   @db.Uuid
  projectId              String                   @db.Uuid
  conversationId         String                   @db.Uuid
  turnId                 String?                  @db.Uuid
  command                String                   @db.VarChar(100)
  schemaVersion          String                   @db.VarChar(50)
  payload                Json                     @default("{}")
  payloadHash            String                   @db.Char(64)
  expectedProjectVersion Int
  risk                   ConversationActionRisk
  status                 ConversationActionStatus @default(PROPOSED)
  diff                   Json                     @default("{}")
  expiresAt              DateTime                 @db.Timestamptz(6)
  result                 Json?
  auditEventId           String?                  @db.Uuid
  createdAt              DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime                 @updatedAt @db.Timestamptz(6)

  conversation ProjectConversation @relation(fields: [workspaceId, projectId, conversationId], references: [workspaceId, projectId, id], onDelete: Cascade)
  turn         ConversationTurn?   @relation(fields: [workspaceId, projectId, turnId], references: [workspaceId, projectId, id], onDelete: Restrict)

  @@unique([workspaceId, projectId, id])
  @@index([workspaceId, projectId, conversationId, status, expiresAt])
  @@map("conversation_actions")
}

model ConversationTurnLease {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @db.Uuid
  projectId    String    @db.Uuid
  turnId       String    @unique @db.Uuid
  ownerId      String    @db.VarChar(200)
  fencingToken BigInt
  acquiredAt   DateTime  @default(now()) @db.Timestamptz(6)
  expiresAt    DateTime  @db.Timestamptz(6)
  releasedAt   DateTime? @db.Timestamptz(6)

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  turn      ConversationTurn @relation(fields: [workspaceId, projectId, turnId], references: [workspaceId, projectId, id], onDelete: Cascade)

  @@unique([workspaceId, projectId, turnId])
  @@index([workspaceId, expiresAt, releasedAt])
  @@map("conversation_turn_leases")
}
