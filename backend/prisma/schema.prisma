generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum Provider {
  KIMI
  DAYTONA
  REDDIT
  GITHUB
  VERCEL
}

enum ConnectionHealth {
  DISCONNECTED
  PENDING
  HEALTHY
  DEGRADED
  REVOKED
  MISCONFIGURED
}

enum SecretScope {
  CONTROL_PLANE
  PROJECT_RUNTIME
}

enum ResearchMode {
  FIXTURE
  AUTHORIZED_IMPORT
  LIVE_REDDIT
}

enum ResearchSourceStatus {
  ACTIVE
  DISABLED
  PURGE_PENDING
  PURGED
}

enum ResearchImportStatus {
  PENDING
  ACCEPTED
  REJECTED
  PURGED
}

enum ProjectStatus {
  DRAFT
  RESEARCHING
  AWAITING_SPEC_APPROVAL
  READY_TO_BUILD
  BUILDING
  AWAITING_RELEASE_APPROVAL
  RELEASED
  PAUSED
  FAILED
  ARCHIVED
}

enum SpecStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SUPERSEDED
  REJECTED
}

enum RunKind {
  RESEARCH
  BUILD
  POLISH
  RELEASE
  ROLLBACK
}

enum RunStatus {
  QUEUED
  RUNNING
  WAITING_FOR_APPROVAL
  CANCEL_REQUESTED
  CANCELED
  SUCCEEDED
  FAILED
}

enum StepStatus {
  PENDING
  RUNNING
  WAITING
  SUCCEEDED
  FAILED
  CANCELED
  SKIPPED
}

enum BudgetStatus {
  RESERVED
  COMMITTED
  RELEASED
  EXCEEDED
}

enum ApprovalKind {
  SPECIFICATION_BUILD
  FIRST_RELEASE
  POLISH_RELEASE
  SECRET_GRANT
  ROLLBACK
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CONSUMED
  SUPERSEDED
}

enum ArtifactKind {
  SOURCE
  VERIFIED_SOURCE
  VERCEL_OUTPUT
  PREVIEW_STATIC
  LOG_EXPORT
}

enum VerificationStatus {
  PENDING
  PASSED
  FAILED
  EXPIRED
}

enum RepositoryStatus {
  PENDING
  READY
  FAILED
  DISCONNECTED
}

enum DeploymentStatus {
  QUEUED
  UPLOADING
  READY_UNPROMOTED
  HEALTH_CHECKING
  HEALTHY
  FAILED
  ROLLED_BACK
  CANCELED
}

enum GrantStatus {
  PENDING
  ACTIVE
  REVOKED
  SUPERSEDED
}

enum ProjectAuthorityMode {
  READ_ONLY
  REVIEW
  AUTOPILOT
}

enum ConversationMessageRole {
  OWNER
  ASSISTANT
  SYSTEM
}

enum ConversationTurnStatus {
  QUEUED
  RUNNING
  CANCEL_REQUESTED
  CANCELED
  COMPLETED
  FAILED
}

enum ConversationEventType {
  TURN_STARTED
  AGENT_STATUS
  TOOL_STARTED
  TOOL_COMPLETED
  ASSISTANT_DELTA
  ACTION_PROPOSED
  ASSISTANT_COMPLETED
  TURN_FAILED
  TURN_CANCELED
  TURN_COMPLETED
}

enum ConversationActionRisk {
  LOW
  MEDIUM
  HIGH
  BLOCKED
}

enum ConversationActionStatus {
  PROPOSED
  EXECUTING
  EXECUTED
  DISMISSED
  EXPIRED
  SUPERSEDED
  FAILED
}

enum ScheduleKind {
  HOURLY_RESEARCH
  FIVE_HOUR_POLISH
}

enum ScheduleStatus {
  ENABLED
  PAUSED
  BACKING_OFF
  BLOCKED
}

enum BillingTier {
  STARTER
  BUILDER
  SCALE
}

enum BillingSubscriptionStatus {
  INACTIVE
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELED
  UNPAID
}

enum BillingCheckoutKind {
  SUBSCRIPTION
  CREDIT_PACK
}

enum BillingCheckoutStatus {
  PENDING
  OPEN
  COMPLETE
  EXPIRED
  FAILED
}

enum CreditReservationStatus {
  HELD
  SETTLED
  RELEASED
}

enum CreditBucket {
  INCLUDED
  PROMOTIONAL
  PURCHASED
}

enum CreditLedgerType {
  PROMOTIONAL_GRANT
  PERIOD_GRANT
  PERIOD_EXPIRY
  PURCHASE
  PURCHASE_EXPIRY
  HACKATHON_CODE_GRANT
  HOLD
  SETTLEMENT
  RELEASE
  ADJUSTMENT
}

enum StripeEventMode {
  TEST
  LIVE
}

enum StripeEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum ActivitySeverity {
  DEBUG
  INFO
  WARNING
  ERROR
  SUCCESS
}

model WaitlistEntry {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique @db.VarChar(320)
  source          String   @default("beta-page") @db.VarChar(80)
  requestCount    Int      @default(1)
  consentedAt     DateTime @default(now()) @db.Timestamptz(6)
  lastRequestedAt DateTime @default(now()) @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@map("waitlist_entries")
}

model Workspace {
  id                     String          @id @default(uuid()) @db.Uuid
  name                   String          @db.VarChar(120)
  status                 WorkspaceStatus @default(ACTIVE)
  timeZone               String          @default("Asia/Singapore") @db.VarChar(100)
  maxConcurrentSandboxes Int             @default(2)
  monthlyBudgetMicros    BigInt          @default(0)
  createdAt              DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime        @updatedAt @db.Timestamptz(6)

  owner                 User?
  setupToken            SetupToken?
  connections           ProviderConnection[]
  secretVersions        SecretVersion[]
  projects              Project[]
  leases                RunLease[]
  outboxEvents          OutboxEvent[]
  inboxReceipts         InboxReceipt[]
  budgetReservations    BudgetReservation[]
  usageEntries          UsageLedger[]
  billingAccount        BillingAccount?
  billingCheckouts      BillingCheckoutSession[]
  billingPeriods        BillingSubscriptionPeriod[]
  creditAccount         CreditAccount?
  creditReservations    CreditReservation[]
  creditLots            CreditLot[]
  creditCodeRedemptions CreditCodeRedemption[]
  creditLedgerEntries   CreditLedger[]
  stripeEvents          StripeEvent[]
  activityEvents        ActivityEvent[]
  auditEvents           AuditEvent[]
  conversations         ProjectConversation[]
  conversationLeases    ConversationTurnLease[]

  @@map("workspaces")
}

model User {
  id            String   @id @default(cuid())
  workspaceId   String   @unique @db.Uuid
  name          String   @db.VarChar(120)
  username      String?  @unique @db.VarChar(30)
  displayUsername String? @db.VarChar(30)
  email         String   @unique @db.VarChar(320)
  emailVerified Boolean  @default(false)
  image         String?  @db.Text
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions              Session[]
  accounts              Account[]
  creditCodeRedemptions CreditCodeRedemption[]

  @@unique([workspaceId, id])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @db.Timestamptz(6)
  ipAddress String?  @db.VarChar(64)
  userAgent String?  @db.Text
  userId    String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String    @db.VarChar(255)
  providerId            String    @db.VarChar(100)
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime? @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(6)
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String   @db.VarChar(320)
  value      String   @db.Text
  expiresAt  DateTime @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  @@index([identifier, expiresAt])
  @@map("verifications")
}

model RateLimit {
  id          String @id @default(cuid())
  key         String @unique @db.VarChar(255)
  count       Int
  lastRequest BigInt

  @@map("rateLimit")
}

model SetupToken {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @unique @db.Uuid
  tokenHash      String    @unique @db.Char(64)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime? @db.Timestamptz(6)
  expiresAt      DateTime  @db.Timestamptz(6)
  consumedAt     DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("setup_tokens")
}

model ProviderConnection {
  id                     String           @id @default(uuid()) @db.Uuid
  workspaceId            String           @db.Uuid
  provider               Provider
  health                 ConnectionHealth @default(DISCONNECTED)
  optimisticVersion      Int              @default(0)
  accountExternalId      String?          @db.VarChar(300)
  accountLabel           String?          @db.VarChar(300)
  scopes                 String[]         @default([])
  maskedSuffix           String?          @db.VarChar(4)
  activeSecretVersionId  String?          @unique @db.Uuid
  pendingSecretVersionId String?          @unique @db.Uuid
  authorizationRef       String?          @db.Text
  authorizedAt           DateTime?        @db.Timestamptz(6)
  lastTestedAt           DateTime?        @db.Timestamptz(6)
  lastHealthyAt          DateTime?        @db.Timestamptz(6)
  failureCode            String?          @db.VarChar(100)
  failureMessage         String?          @db.VarChar(500)
  connectedAt            DateTime?        @db.Timestamptz(6)
  disconnectedAt         DateTime?        @db.Timestamptz(6)
  createdAt              DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime         @updatedAt @db.Timestamptz(6)

  workspace            Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  secretVersions       SecretVersion[] @relation("ConnectionSecrets")
  activeSecretVersion  SecretVersion?  @relation("ActiveConnectionSecret", fields: [activeSecretVersionId], references: [id], onDelete: SetNull)
  pendingSecretVersion SecretVersion?  @relation("PendingConnectionSecret", fields: [pendingSecretVersionId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, provider])
  @@index([workspaceId, health])
  @@map("provider_connections")
}

model SecretVersion {
  id                   String      @id @default(uuid()) @db.Uuid
  workspaceId          String      @db.Uuid
  projectId            String?     @db.Uuid
  providerConnectionId String?     @db.Uuid
  scope                SecretScope
  logicalKey           String      @db.VarChar(240)
  name                 String      @db.VarChar(100)
  version              Int
  algorithm            String      @default("A256GCM") @db.VarChar(32)
  keyProvider          String      @db.VarChar(32)
  keyId                String      @db.VarChar(500)
  ciphertext           Bytes
  wrappedDataKey       Bytes
  iv                   Bytes
  authTag              Bytes
  wrapIv               Bytes?
  wrapAuthTag          Bytes?
  contextHash          String      @db.Char(64)
  maskedSuffix         String      @db.VarChar(4)
  createdByUserId      String?
  revokedAt            DateTime?   @db.Timestamptz(6)
  createdAt            DateTime    @default(now()) @db.Timestamptz(6)

  workspace            Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project              Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  providerConnection   ProviderConnection?  @relation("ConnectionSecrets", fields: [providerConnectionId], references: [id], onDelete: Cascade)
  activeForConnection  ProviderConnection?  @relation("ActiveConnectionSecret")
  pendingForConnection ProviderConnection?  @relation("PendingConnectionSecret")
  grants               ProjectSecretGrant[]

  @@unique([workspaceId, projectId, id])
  @@unique([workspaceId, logicalKey, version])
  @@index([workspaceId, projectId, scope, revokedAt])
  @@index([providerConnectionId])
  @@map("secret_versions")
}

model Project {
  id                   String        @id @default(uuid()) @db.Uuid
  workspaceId          String        @db.Uuid
  name                 String        @db.VarChar(120)
  slug                 String        @db.VarChar(80)
  marketLabel          String        @db.VarChar(120)
  researchContext      String        @db.Text
  researchMode         ResearchMode
  config               Json
  status               ProjectStatus @default(DRAFT)
  authorityMode        ProjectAuthorityMode @default(READ_ONLY)
  optimisticVersion    Int           @default(0)
  currentBlocker       String?       @db.VarChar(500)
  selectedFindingId    String?       @db.Uuid
  currentSpecVersionId String?       @db.Uuid
  archivedAt           DateTime?     @db.Timestamptz(6)
  createdAt            DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @db.Timestamptz(6)

  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  secretVersions SecretVersion[]
  sources        ResearchSource[]
  imports        ResearchImport[]
  findings       Finding[]
  specVersions   ProductSpecVersion[]
  runs           WorkflowRun[]
  approvals      Approval[]
  repository     RepositoryBinding?
  deployments    Deployment[]
  schedules      Schedule[]
  conversations  ProjectConversation[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, slug])
  @@index([workspaceId, status, updatedAt(sort: Desc)])
  @@map("projects")
}

model ResearchSource {
  id                     String               @id @default(uuid()) @db.Uuid
  workspaceId            String               @db.Uuid
  projectId              String               @db.Uuid
  mode                   ResearchMode
  status                 ResearchSourceStatus @default(ACTIVE)
  label                  String               @db.VarChar(120)
  externalRef            String?              @db.VarChar(500)
  authorizationReference String?              @db.Text
  authorizedAt           DateTime?            @db.Timestamptz(6)
  metadata               Json                 @default("{}")
  purgeRequestedAt       DateTime?            @db.Timestamptz(6)
  purgedAt               DateTime?            @db.Timestamptz(6)
  createdAt              DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime             @updatedAt @db.Timestamptz(6)

  project   Project            @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Cascade)
  imports   ResearchImport[]
  documents ResearchDocument[]

  @@unique([workspaceId, projectId, id])
  @@index([workspaceId, projectId, status])
  @@map("research_sources")
}

model ResearchImport {
  id            String               @id @default(uuid()) @db.Uuid
  workspaceId   String               @db.Uuid
  projectId     String               @db.Uuid
  sourceId      String               @db.Uuid
  status        ResearchImportStatus @default(PENDING)
  schemaVersion String               @db.VarChar(50)
  objectKey     String               @db.VarChar(1024)
  contentHash   String               @db.Char(64)
  documentCount Int
  byteSize      Int
  rawExpiresAt  DateTime             @db.Timestamptz(6)
  rejectionCode String?              @db.VarChar(100)
  createdAt     DateTime             @default(now()) @db.Timestamptz(6)
  acceptedAt    DateTime?            @db.Timestamptz(6)
  purgedAt      DateTime?            @db.Timestamptz(6)

  project   Project            @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Cascade)
  source    ResearchSource     @relation(fields: [workspaceId, projectId, sourceId], references: [workspaceId, projectId, id], onDelete: Restrict)
  documents ResearchDocument[]

  @@unique([workspaceId, projectId, id])
  @@unique([workspaceId, projectId, contentHash])
  @@index([rawExpiresAt, purgedAt])
  @@map("research_imports")
}

model ResearchDocument {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String    @db.Uuid
  projectId         String    @db.Uuid
  sourceId          String    @db.Uuid
  importId          String?   @db.Uuid
  externalId        String    @db.VarChar(300)
  title             String    @db.VarChar(500)
  body              String    @db.Text
  permalink         String?   @db.Text
  attribution       String    @db.VarChar(300)
  contentHash       String    @db.Char(64)
  sourcePublishedAt DateTime? @db.Timestamptz(6)
  rawExpiresAt      DateTime  @db.Timestamptz(6)
  purgedAt          DateTime? @db.Timestamptz(6)
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  source ResearchSource  @relation(fields: [workspaceId, projectId, sourceId], references: [workspaceId, projectId, id], onDelete: Cascade)
  import ResearchImport? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, projectId, sourceId, externalId])
  @@index([workspaceId, projectId, rawExpiresAt])
  @@map("research_documents")
}

model Finding {
  id                    String       @id @default(uuid()) @db.Uuid
  workspaceId           String       @db.Uuid
  projectId             String       @db.Uuid
  title                 String       @db.VarChar(200)
  problemSummary        String       @db.Text
  solutionConcept       String?      @db.Text
  audience              String       @db.Text
  originMode            ResearchMode @default(FIXTURE)
  frequencyScore        Decimal      @db.Decimal(5, 2)
  severityScore         Decimal      @db.Decimal(5, 2)
  willingnessToPayScore Decimal      @db.Decimal(5, 2)
  feasibilityScore      Decimal      @db.Decimal(5, 2)
  totalScore            Decimal      @db.Decimal(5, 2)
  scoreExplanation      String       @db.Text
  selectedAt            DateTime?    @db.Timestamptz(6)
  model                 String       @db.VarChar(120)
  promptVersion         String       @db.VarChar(100)
  schemaVersion         String       @db.VarChar(100)
  createdAt             DateTime     @default(now()) @db.Timestamptz(6)

  project      Project              @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Cascade)
  evidence     EvidenceExcerpt[]
  specVersions ProductSpecVersion[]

  @@unique([workspaceId, projectId, id])
  @@index([workspaceId, projectId, totalScore(sort: Desc)])
  @@index([workspaceId, originMode])
  @@map("findings")
}

model EvidenceExcerpt {
  id                      String    @id @default(uuid()) @db.Uuid
  workspaceId             String    @db.Uuid
  projectId               String    @db.Uuid
  findingId               String    @db.Uuid
  sourceExternalId        String    @db.VarChar(300)
  excerpt                 String    @db.VarChar(1500)
  permalink               String?   @db.Text
  attribution             String    @db.VarChar(300)
  contentHash             String    @db.Char(64)
  sourcePublishedAt       DateTime? @db.Timestamptz(6)
  capturedAt              DateTime  @default(now()) @db.Timestamptz(6)
  retainedBySpecVersionId String?   @db.Uuid

  finding Finding @relation(fields: [workspaceId, projectId, findingId], references: [workspaceId, projectId, id], onDelete: Cascade)

  @@unique([workspaceId, projectId, id])
  @@index([workspaceId, projectId, retainedBySpecVersionId])
  @@map("evidence_excerpts")
}

model ProductSpecVersion {
  id                String     @id @default(uuid()) @db.Uuid
  workspaceId       String     @db.Uuid
  projectId         String     @db.Uuid
  basedOnFindingId  String     @db.Uuid
  version           Int
  optimisticVersion Int        @default(0)
  status            SpecStatus @default(DRAFT)
  content           Json
  contentHash       String     @db.Char(64)
  model             String?    @db.VarChar(120)
  promptVersion     String?    @db.VarChar(100)
  schemaVersion     String     @db.VarChar(100)
  createdByUserId   String?
  approvedAt        DateTime?  @db.Timestamptz(6)
  supersededAt      DateTime?  @db.Timestamptz(6)
  createdAt         DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @db.Timestamptz(6)

  project   Project       @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Cascade)
  finding   Finding       @relation(fields: [workspaceId, projectId, basedOnFindingId], references: [workspaceId, projectId, id], onDelete: Restrict)
  runs      WorkflowRun[]
  approvals Approval[]

  @@unique([workspaceId, projectId, id])
  @@unique([projectId, version])
  @@index([workspaceId, projectId, status, version(sort: Desc)])
  @@map("product_spec_versions")
}

model WorkflowRun {
  id                  String    @id @default(uuid()) @db.Uuid
  workspaceId         String    @db.Uuid
  projectId           String    @db.Uuid
  specVersionId       String?   @db.Uuid
  parentRunId         String?   @db.Uuid
  scheduleId          String?   @db.Uuid
  kind                RunKind
  status              RunStatus @default(QUEUED)
  stateVersion        Int       @default(0)
  attempt             Int       @default(1)
  currentStepKey      String?   @db.VarChar(100)
  idempotencyKey      String    @db.VarChar(200)
  budgetCeilingMicros BigInt
  reservedMicros      BigInt    @default(0)
  actualCostMicros    BigInt    @default(0)
  cancelRequestedAt   DateTime? @db.Timestamptz(6)
  startedAt           DateTime? @db.Timestamptz(6)
  finishedAt          DateTime? @db.Timestamptz(6)
  lastHeartbeatAt     DateTime? @db.Timestamptz(6)
  failureCode         String?   @db.VarChar(100)
  failureMessage      String?   @db.VarChar(1000)
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)

  project            Project             @relation(fields: [workspaceId, projectId], references: [workspaceId, id], onDelete: Cascade)
  specVersion        ProductSpecVersion? @relation(fields: [workspaceId, projectId, specVersionId], references: [workspaceId, projectId, id], onDelete: Restrict)
  parentRun          WorkflowRun?        @relation("RunRetryChain", fields: [workspaceId, projectId, parentRunId], references: [workspaceId, projectId, id], onDelete: Restrict)
  childRuns          WorkflowRun[]       @relation("RunRetryChain")
  schedule           Schedule?           @relation(fields: [workspaceId, projectId, scheduleId], references: [workspaceId, projectId, id], onDelete: Restrict)
  steps              WorkflowStep[]
  budgetReservations BudgetReservation[]
  usageEntries       UsageLedger[]
  creditReservations CreditReservation[]
  artifacts          BuildArtifact[]

  @@unique([workspaceId, projectId, id])
  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, projectId, status, createdAt(sort: Desc)])
  @@index([workspaceId, status, lastHeartbeatAt])
  @@map("workflow_runs")
}

model WorkflowStep {
  id             String     @id @default(uuid()) @db.Uuid
  workspaceId    String     @db.Uuid
  projectId      String     @db.Uuid
  runId          String     @db.Uuid
  key            String     @db.VarChar(100)
  label          String     @db.VarChar(200)
  status         StepStatus @default(PENDING)
  attempt        Int        @default(1)
  inputHash      String?    @db.Char(64)
  output         Json?
  outputHash     String?    @db.Char(64)
  startedAt      DateTime?  @db.Timestamptz(6)
  finishedAt     DateTime?  @db.Timestamptz(6)
  failureCode    String?    @db.VarChar(100)
  failureMessage String?    @db.VarChar(1000)
  createdAt      DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime   @updatedAt @db.Timestamptz(6)

  run WorkflowRun @relation(fields: [workspaceId, projectId, runId], references: [workspaceId, projectId, id], onDelete: Cascade)

  @@unique([runId, key, attempt])
  @@index([workspaceId, runId, status])
